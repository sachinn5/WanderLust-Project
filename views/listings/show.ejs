<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-3">

  
  
    <h3>Listing Details :</h3>
    <div class="card col-6 offset-1 show-card">
      <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_image">
      <div class="card-body">
      <p class="card-text"><%= listing.title %> 
      </p>
  </div>
    </div>
    <ul>
      <li><%= listing.title %></li>
      <li><%= listing.description %></li>
      <li>&#8377; <%= listing.price.toLocaleString("en-IN") %></li>
      <li><%= listing.location %></li>
      <li><%= listing.country %></li>
    </ul>
    
    <br />
    <div class="btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-1 edit-btn">Edit </a>
  
      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark  offest-1">Delete</button>
      </form> 
    </div>
</div>
</div>